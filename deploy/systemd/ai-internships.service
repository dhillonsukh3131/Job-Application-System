[Unit]
Description=AI Internship Tracker (hourly)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/workspace/Job-Application-System
EnvironmentFile=/workspace/Job-Application-System/.env
ExecStart=/workspace/Job-Application-System/scripts/run_ai_tracker.sh

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
